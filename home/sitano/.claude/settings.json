{
  "statusLine": {
    "type": "command",
    "command": "mise exec node -- npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "superpowers-extended-cc@superpowers-extended-cc-marketplace": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-extended-cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "pcvelz/superpowers"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "mise exec node -- npx tsx \"$HOME/.claude/hooks/notification-desktop.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "theme": "dark-daltonized"
}
